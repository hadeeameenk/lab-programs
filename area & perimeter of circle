#include <stdio.h>
#include <math.h>

#define PI 3.14159

double calculateDiameter(int x1, int y1, int x2, int y2);
double calculatePerimeter(double diameter);
double calculateArea(double diameter);

int main() {
    int x1, y1, x2, y2;

    printf("Enter coordinates of point 1 (x1 y1): ");
    scanf("%d %d", &x1, &y1);
    printf("Enter coordinates of point 2 (x2 y2): ");
    scanf("%d %d", &x2, &y2);

    double diameter = calculateDiameter(x1, y1, x2, y2);
    
    double perimeter = calculatePerimeter(diameter);
    double area = calculateArea(diameter);

    printf("Diameter:      %.2f\n", diameter);
    printf("Perimeter:     %.2f\n", perimeter);
    printf("Area:          %.2f\n", area);

    return 0;
}

double calculateDiameter(int x1, int y1, int x2, int y2) {

    double dx = (double)x2 - (double)x1;
    double dy = (double)y2 - (double)y1;
    
    return sqrt(pow(dx, 2) + pow(dy, 2));
}

double calculatePerimeter(double diameter) {
    return PI * diameter;
}

double calculateArea(double diameter) {
    double radius = diameter / 2.0;
    return PI * pow(radius, 2);
}
